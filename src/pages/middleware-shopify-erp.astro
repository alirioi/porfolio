---
import StandaloneLayout from "../layouts/StandaloneLayout.astro";

import DecoIcon from "../components/icons/DecoIcon.astro";
import TriangleAlertIcon from "../components/icons/TriangleAlertIcon.astro";
import ChevronRightIcon from "../components/icons/ChevronRightIcon.astro";
import Shopify from "../components/icons/Shopify.astro";
import ShopmonkeyIcon from "../components/icons/ShopmonkeyIcon.astro";
import LightbulbIcon from "../components/icons/LightbulbIcon.astro";
import CheckIcon from "../components/icons/CheckIcon.astro";
---

<StandaloneLayout
  title="Automatización B2B: Shopify ↔ Shopmonkey ERP"
  description="Arquitectura serverless para sincronización Shopify-ERP."
>
  <main class="min-h-screen p-4 md:p-8 flex items-center justify-center">
    <div class="max-w-7xl w-full flex flex-col gap-6">
      <header
        class="panel-bg border border-dark-200 rounded-xl p-6 flex flex-col md:flex-row items-center justify-between relative overflow-hidden my-12"
      >
        <div class="z-10 w-full text-center">
          <h1
            class="text-2xl md:text-3xl font-bold text-dark-50 mb-2 uppercase"
          >
            Automatización B2B: <span class="glow-text-primary">Shopify</span>
            <span class="text-[var(--color-dark-400)] mx-2">↔</span>
            <span class="glow-text-accent">Shopmonkey ERP</span>
          </h1>
          <h2
            class="text-[var(--color-dark-400)] text-sm md:text-base tracking-widest uppercase font-semibold"
          >
            Middleware Serverless con Node.js
          </h2>
        </div>

        <div
          class="hidden md:flex absolute inset-0 items-center justify-center pointer-events-none opacity-80"
        >
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr_1fr] gap-6">
        <section
          class="flex flex-col gap-4 border-r-0 lg:border-r border-[var(--color-dark-200)] pr-0 lg:pr-6"
        >
          <div class="flex items-center gap-4 mb-2">
            <TriangleAlertIcon
              class="w-10 h-10 glow-text-primary glow-svg-primary"
            />
            <h3 class="text-xl font-bold text-[var(--color-dark-50)] ml-2">
              El Reto
            </h3>
          </div>

          <div
            class="panel-bg p-4 rounded-lg glow-border-primary flex items-start gap-3"
          >
            <ChevronRightIcon
              class="w-5 h-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0"
            />
            <p class="text-sm text-[var(--color-dark-50)] leading-relaxed">
              Entrada manual de datos para cientos de órdenes semanales.
            </p>
          </div>

          <div
            class="panel-bg p-4 rounded-lg glow-border-primary flex items-start gap-3"
          >
            <ChevronRightIcon
              class="w-5 h-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0"
            />
            <p class="text-sm text-[var(--color-dark-50)] leading-relaxed">
              Creación de perfiles de clientes duplicados en el ERP.
            </p>
          </div>

          <div
            class="panel-bg p-4 rounded-lg glow-border-primary flex items-start gap-3"
          >
            <ChevronRightIcon
              class="w-5 h-5 text-[var(--color-primary)] mt-0.5 flex-shrink-0"
            />
            <p class="text-sm text-[var(--color-dark-50)] leading-relaxed">
              Errores contables al sincronizar ventas de dropshipping con
              tarifas variables de mano de obra.
            </p>
          </div>
        </section>

        <section
          class="flex items-center justify-center relative py-12 lg:py-0"
        >
          <div class="flex items-center w-full max-w-lg mx-auto">
            <div class="flex flex-col items-center relative z-10">
              <div
                class="p-3 bg-[var(--color-dark)] rounded-xl border border-[var(--color-dark-200)] glow-border-primary"
              >
                <Shopify
                  class="w-12 h-12 text-[var(--color-primary)] glow-svg-primary"
                />
              </div>
            </div>

            <div
              class="flex-1 flex flex-col items-center justify-center relative -mx-2 z-0"
            >
              <span
                class="absolute -top-8 text-xs text-dark-50 font-mono tracking-widest text-center rounded-full border border-primary-700 py-1 px-3"
                >WEBHOOKS</span
              >
              <svg
                class="w-full h-12 preserve-3d"
                viewBox="0 0 100 40"
                preserveAspectRatio="none"
              >
                <path
                  d="M0,20 L30,20 L35,5 L45,35 L50,20 L100,20"
                  stroke="var(--color-primary)"
                  fill="none"
                  stroke-width="2"
                  class="glow-svg-primary"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path
                  d="M10,20 L90,20"
                  stroke="var(--color-primary)"
                  fill="none"
                  stroke-width="1.5"
                  opacity="0.4"
                  class="pulse-line"></path>
                <polygon
                  points="95,15 100,20 95,25"
                  fill="var(--color-primary)"
                  class="glow-svg-primary"></polygon>
              </svg>
              <span
                class="absolute -bottom-8 text-xs text-dark-50 font-mono tracking-widest text-center rounded-full border border-primary-700 py-1 px-3"
                >API GET</span
              >
            </div>

            <div class="flex flex-col items-center relative z-10">
              <div
                class="p-4 bg-dark rounded-full border border-dark-200 glow-border-white"
              >
                <DecoIcon class="w-14 h-14 text-dark-50 glow-svg-white" />
              </div>
            </div>

            <div
              class="flex-1 flex flex-col items-center justify-center relative -mx-2 z-0"
            >
              <span
                class="absolute -top-8 text-xs text-dark-50 font-mono tracking-widest text-center rounded-full border border-accent py-1 px-3"
                >&#123; x* &#125; REGEX</span
              >
              <svg
                class="w-full h-12"
                viewBox="0 0 100 40"
                preserveAspectRatio="none"
              >
                <path
                  d="M0,20 L40,20 L45,5 L55,35 L60,20 L100,20"
                  stroke="var(--color-accent)"
                  fill="none"
                  stroke-width="2"
                  class="glow-svg-accent"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path
                  d="M10,20 L90,20"
                  stroke="var(--color-accent)"
                  fill="none"
                  stroke-width="1.5"
                  opacity="0.4"
                  class="pulse-line"></path>
                <polygon
                  points="95,15 100,20 95,25"
                  fill="var(--color-accent)"
                  class="glow-svg-accent"></polygon>
              </svg>
              <span
                class="absolute -bottom-8 text-xs text-dark-50 font-mono tracking-widest text-center rounded-full border border-accent py-1 px-3"
                >SKU <span class="mx-1">→</span> ERP</span
              >
            </div>

            <div class="flex flex-col items-center relative z-10">
              <div
                class="p-3 bg-[var(--color-dark)] rounded-xl border border-[var(--color-dark-200)] glow-border-accent"
              >
                <ShopmonkeyIcon
                  class="w-12 h-12 text-[var(--color-accent)] glow-svg-accent"
                />
              </div>
            </div>
          </div>
        </section>

        <section
          class="flex flex-col gap-4 border-l-0 lg:border-l border-[var(--color-dark-200)] pl-0 lg:pl-6"
        >
          <div
            class="flex items-center gap-4 mb-2 justify-end lg:justify-start"
          >
            <h3
              class="text-xl font-bold text-[var(--color-dark-50)] mr-2 lg:mr-0 order-2 lg:order-last"
            >
              La Solución
            </h3>
            <LightbulbIcon
              class="w-10 h-10 glow-text-accent glow-svg-accent order-1 lg:order-first"
            />
          </div>

          <div
            class="panel-bg p-4 rounded-lg glow-border-accent flex items-start gap-3"
          >
            <CheckIcon
              class="w-5 h-5 text-[var(--color-accent)] mt-0.5 flex-shrink-0"
            />
            <p class="text-sm text-[var(--color-dark-50)] leading-relaxed">
              <strong class="text-white block mb-1 font-semibold"
                >Interceptación en Tiempo Real:</strong
              >
              Webhooks de Shopify procesados mediante Pipedream.
            </p>
          </div>

          <div
            class="panel-bg p-4 rounded-lg glow-border-accent flex items-start gap-3"
          >
            <CheckIcon
              class="w-5 h-5 text-[var(--color-accent)] mt-0.5 flex-shrink-0"
            />
            <p class="text-sm text-[var(--color-dark-50)] leading-relaxed">
              <strong class="text-white block mb-1 font-semibold"
                >Normalización de Datos:</strong
              >
              Limpieza de strings (Regex) y prevención de duplicados vía API GET.
            </p>
          </div>

          <div
            class="panel-bg p-4 rounded-lg glow-border-accent flex items-start gap-3"
          >
            <CheckIcon
              class="w-5 h-5 text-[var(--color-accent)] mt-0.5 flex-shrink-0"
            />
            <p class="text-sm text-[var(--color-dark-50)] leading-relaxed">
              <strong class="text-white block mb-1 font-semibold"
                >Transformación de Datos:</strong
              >
              Mapeo de SKUs de e-commerce a "Números de Parte" en el ERP para gestionar
              la estructura de precios fijos del ERP y asegurar la precisión contable.
            </p>
          </div>
        </section>
      </div>
    </div>
  </main>
</StandaloneLayout>

<style>
  /* ... Tus estilos se mantienen exactamente igual que en el código anterior ... */
  .panel-bg {
    background-color: var(--color-dark);
  }
  .glow-border-primary {
    border: 1px solid var(--color-primary-700);
    box-shadow: inset 0 0 10px rgba(76, 175, 80, 0.05);
    transition: all 0.3s ease;
  }
  .glow-border-primary:hover {
    border-color: var(--color-primary);
    box-shadow:
      0 0 15px rgba(76, 175, 80, 0.2),
      inset 0 0 10px rgba(76, 175, 80, 0.1);
  }
  .glow-text-primary {
    text-shadow: 0 0 12px var(--color-primary);
    color: var(--color-primary);
  }
  .glow-svg-primary {
    filter: drop-shadow(0 0 8px var(--color-primary));
  }
  .glow-border-accent {
    border: 1px solid rgba(0, 247, 255, 0.3);
    box-shadow: inset 0 0 10px rgba(0, 247, 255, 0.05);
    transition: all 0.3s ease;
  }
  .glow-border-accent:hover {
    border-color: var(--color-accent);
    box-shadow:
      0 0 15px rgba(0, 247, 255, 0.2),
      inset 0 0 10px rgba(0, 247, 255, 0.1);
  }
  .glow-text-accent {
    text-shadow: 0 0 12px var(--color-accent);
    color: var(--color-accent);
  }
  .glow-svg-accent {
    filter: drop-shadow(0 0 8px var(--color-accent));
  }

  .glow-border-white {
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: inset 0 0 10px rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
  }

  .glow-border-white:hover {
    border-color: var(--color-dark-50);
    box-shadow:
      0 0 15px rgba(255, 255, 255, 0.2),
      inset 0 0 10px rgba(255, 255, 255, 0.1);
  }

  .glow-text-white {
    text-shadow: 0 0 12px var(--color-dark-50);
    color: var(--color-dark-50);
  }

  .glow-svg-white {
    filter: drop-shadow(0 0 8px var(--color-dark-50));
  }

  @keyframes dash {
    to {
      stroke-dashoffset: -20;
    }
  }
  .pulse-line {
    stroke-dasharray: 5, 5;
    animation: dash 1s linear infinite;
  }
</style>
